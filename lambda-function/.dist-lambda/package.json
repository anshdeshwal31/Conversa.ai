{
    "name": "bot-scheduler-lambda",
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "prisma:generate": "dotenv -e ../.env -- prisma generate --schema=./prisma/schema.prisma",
        "prisma:migrate": "dotenv -e ../.env -- prisma migrate deploy --schema=./prisma/schema.prisma",
        "build": "npm run prisma:generate && tsc index.ts --target ES2022 --module NodeNext --moduleResolution NodeNext --outDir build"
    },
    "dependencies": {
        "@prisma/client": "^5.0.0",
        "prisma": "^5.0.0",
        "google-auth-library": "^9.0.0"
    },
    "devDependencies": {
        "dotenv-cli": "^8.0.0",
        "typescript": "^5.9.3"
    }
}